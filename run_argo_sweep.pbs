#!/bin/bash -l
#PBS -N alcf-argo-sweep
#PBS -l select=1:system=crux
#PBS -l place=scatter
#PBS -l walltime=4:00:00
#PBS -q workq-route
#PBS -A datascience
#PBS -l filesystems=home
#PBS -o logs/argo_sweep.out
#PBS -e logs/argo_sweep.err

# ============================================================
# ALCF Argo API — Full Model × Prompt × Concurrency Sweep
#
# Tests commercial models available through the ALCF Argo proxy
# against short/medium/long prompts across concurrency levels.
# Results written to results/ as individual JSON files.
# Run plot_results.py afterward to generate figures.
# ============================================================

set -euo pipefail

VENV="${HOME}/crux/alcf-inference-venv"
REPO_DIR="${HOME}/crux/crux-agent-benchmarks"

# Argo auth — just use your ANL username as the API key
export ARGO_API_KEY="jchilders"

# Proxy — required for outbound HTTPS from compute nodes
export http_proxy="http://proxy.alcf.anl.gov:3128"
export https_proxy="http://proxy.alcf.anl.gov:3128"
export ftp_proxy="http://proxy.alcf.anl.gov:3128"
export HTTP_PROXY="http://proxy.alcf.anl.gov:3128"
export HTTPS_PROXY="http://proxy.alcf.anl.gov:3128"

# Models to benchmark via Argo
MODELS=(
    "Claude Sonnet 4.6"
    "GPT-5"
    "Claude Opus 4.7"
    "GPT-4.1"
    "Gemini 2.5 Flash"
)

PROMPT_SIZES=("short" "medium" "long")
SWEEP_LEVELS="1,2,4,8,16,32"
WAVES=3
MAX_TOKENS=256

echo "=========================================="
echo "Job ID:    ${PBS_JOBID}"
echo "Node:      $(hostname)"
echo "Started:   $(date)"
echo "Backend:   argo"
echo "Models:    ${#MODELS[@]}"
echo "Prompts:   ${PROMPT_SIZES[*]}"
echo "Levels:    ${SWEEP_LEVELS}"
echo "=========================================="

cd "${REPO_DIR}"
mkdir -p logs results

source "${VENV}/bin/activate"
echo "Python: $(which python) $(python --version)"
echo ""

TOTAL=$((${#MODELS[@]} * ${#PROMPT_SIZES[@]}))
COUNT=0

for MODEL in "${MODELS[@]}"; do
    # Sanitize model name for use in filenames (spaces→_, dots→_)
    MODEL_SLUG=$(echo "${MODEL}" | tr ' /' '__' | tr '.' '_')

    for PROMPT_SIZE in "${PROMPT_SIZES[@]}"; do
        COUNT=$((COUNT + 1))
        echo ""
        echo "══════════════════════════════════════════════════════════════"
        echo "  [${COUNT}/${TOTAL}] Model: ${MODEL}  |  Prompt: ${PROMPT_SIZE}"
        echo "══════════════════════════════════════════════════════════════"

        OUTPUT="results/argo_sweep_${MODEL_SLUG}_${PROMPT_SIZE}.json"

        # Skip if already done (allows re-run on partial failure)
        if [ -f "${OUTPUT}" ]; then
            echo "  Already exists, skipping: ${OUTPUT}"
            continue
        fi

        python benchmark.py \
            --backend argo \
            --api-key "${ARGO_API_KEY}" \
            --model "${MODEL}" \
            --max-tokens "${MAX_TOKENS}" \
            --waves "${WAVES}" \
            --sweep \
            --sweep-levels "${SWEEP_LEVELS}" \
            --prompt-size "${PROMPT_SIZE}" \
            --output "${OUTPUT}" \
            2>&1 || echo "  WARNING: run failed for ${MODEL} / ${PROMPT_SIZE}, continuing..."

        # Brief pause between models to avoid hammering the endpoint
        sleep 5
    done
done

echo ""
echo "=========================================="
echo "All Argo sweeps complete."
echo "Finished: $(date)"
echo "Results:"
ls -lh results/argo_sweep_*.json 2>/dev/null | awk '{print "  "$NF, $5}'
echo "=========================================="
